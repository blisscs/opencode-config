{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#FFFFFF",
    "fg": "#1A1A1A",
    "primary": "#2563EB",
    "secondary": "#7C3AED",
    "accent": "#EA580C",
    "success": "#16A34A",
    "warning": "#CA8A04",
    "error": "#DC2626",
    "muted": "#6B7280",
    "border": "#E5E7EB",
    "surface": "#F9FAFB",
    "highlight": "#FEF3C7",
    "cyan": "#0891B2"
  },
  "theme": {
    "primary": { "dark": "primary", "light": "primary" },
    "secondary": { "dark": "secondary", "light": "secondary" },
    "accent": { "dark": "accent", "light": "accent" },
    "error": { "dark": "error", "light": "error" },
    "warning": { "dark": "warning", "light": "warning" },
    "success": { "dark": "success", "light": "success" },
    "info": { "dark": "primary", "light": "primary" },
    "text": { "dark": "fg", "light": "fg" },
    "textMuted": { "dark": "muted", "light": "muted" },
    "background": { "dark": "bg", "light": "bg" },
    "backgroundPanel": { "dark": "surface", "light": "surface" },
    "backgroundElement": { "dark": "surface", "light": "surface" },
    "border": { "dark": "border", "light": "border" },
    "borderActive": { "dark": "muted", "light": "muted" },
    "borderSubtle": { "dark": "border", "light": "border" },
    "diffAdded": { "dark": "success", "light": "success" },
    "diffRemoved": { "dark": "error", "light": "error" },
    "diffContext": { "dark": "muted", "light": "muted" },
    "diffHunkHeader": { "dark": "muted", "light": "muted" },
    "diffHighlightAdded": { "dark": "success", "light": "success" },
    "diffHighlightRemoved": { "dark": "error", "light": "error" },
    "diffAddedBg": { "dark": "#F0FDF4", "light": "#F0FDF4" },
    "diffRemovedBg": { "dark": "#FEF2F2", "light": "#FEF2F2" },
    "diffContextBg": { "dark": "surface", "light": "surface" },
    "diffLineNumber": { "dark": "border", "light": "border" },
    "diffAddedLineNumberBg": { "dark": "#F0FDF4", "light": "#F0FDF4" },
    "diffRemovedLineNumberBg": { "dark": "#FEF2F2", "light": "#FEF2F2" },
    "markdownText": { "dark": "fg", "light": "fg" },
    "markdownHeading": { "dark": "primary", "light": "primary" },
    "markdownLink": { "dark": "secondary", "light": "secondary" },
    "markdownLinkText": { "dark": "accent", "light": "accent" },
    "markdownCode": { "dark": "success", "light": "success" },
    "markdownBlockQuote": { "dark": "muted", "light": "muted" },
    "markdownEmph": { "dark": "accent", "light": "accent" },
    "markdownStrong": { "dark": "warning", "light": "warning" },
    "markdownHorizontalRule": { "dark": "border", "light": "border" },
    "markdownListItem": { "dark": "primary", "light": "primary" },
    "markdownListEnumeration": { "dark": "accent", "light": "accent" },
    "markdownImage": { "dark": "secondary", "light": "secondary" },
    "markdownImageText": { "dark": "accent", "light": "accent" },
    "markdownCodeBlock": { "dark": "fg", "light": "fg" },
    "syntaxComment": { "dark": "muted", "light": "muted" },
    "syntaxKeyword": { "dark": "secondary", "light": "secondary" },
    "syntaxFunction": { "dark": "primary", "light": "primary" },
    "syntaxVariable": { "dark": "fg", "light": "fg" },
    "syntaxString": { "dark": "success", "light": "success" },
    "syntaxNumber": { "dark": "accent", "light": "accent" },
    "syntaxType": { "dark": "cyan", "light": "cyan" },
    "syntaxOperator": { "dark": "error", "light": "error" },
    "syntaxPunctuation": { "dark": "fg", "light": "fg" }
  }
}
